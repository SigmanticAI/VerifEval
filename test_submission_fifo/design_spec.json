{
  "design_name": "sync_fifo",
  "description": "Synchronous FIFO with parameterizable depth and data width, featuring write/read interfaces, status flags (full, empty, almost_full, almost_empty), count tracking, and error detection for overflow/underflow conditions",
  "modules": [
    {
      "name": "sync_fifo",
      "description": "Main synchronous FIFO module with circular buffer implementation, pointer management, and status flag generation",
      "ports": [
        {
          "name": "clk",
          "direction": "input",
          "width": 1,
          "description": "System clock"
        },
        {
          "name": "rst_n",
          "direction": "input",
          "width": 1,
          "description": "Active-low asynchronous reset"
        },
        {
          "name": "wr_en",
          "direction": "input",
          "width": 1,
          "description": "Write enable signal"
        },
        {
          "name": "wr_data",
          "direction": "input",
          "width": "DATA_WIDTH",
          "description": "Data to be written to FIFO"
        },
        {
          "name": "rd_en",
          "direction": "input",
          "width": 1,
          "description": "Read enable signal"
        },
        {
          "name": "rd_data",
          "direction": "output",
          "width": "DATA_WIDTH",
          "description": "Data read from FIFO (combinational)"
        },
        {
          "name": "full",
          "direction": "output",
          "width": 1,
          "description": "FIFO full flag"
        },
        {
          "name": "empty",
          "direction": "output",
          "width": 1,
          "description": "FIFO empty flag"
        },
        {
          "name": "almost_full",
          "direction": "output",
          "width": 1,
          "description": "FIFO almost full flag (>= 3/4 depth)"
        },
        {
          "name": "almost_empty",
          "direction": "output",
          "width": 1,
          "description": "FIFO almost empty flag (<= 1/4 depth)"
        },
        {
          "name": "count",
          "direction": "output",
          "width": "ADDR_WIDTH+1",
          "description": "Current number of entries in FIFO"
        },
        {
          "name": "error",
          "direction": "output",
          "width": 1,
          "description": "Error flag for overflow/underflow (sticky)"
        }
      ],
      "parameters": [
        {
          "name": "DATA_WIDTH",
          "default": "8",
          "description": "Width of data bus in bits"
        },
        {
          "name": "DEPTH",
          "default": "16",
          "description": "FIFO depth (number of entries)"
        },
        {
          "name": "ADDR_WIDTH",
          "default": "$clog2(DEPTH)",
          "description": "Address width for pointer calculations"
        }
      ],
      "fsms": [
        {
          "name": "fifo_state_machine",
          "states": [
            "EMPTY",
            "NORMAL",
            "ALMOST_EMPTY",
            "ALMOST_FULL",
            "FULL",
            "ERROR"
          ],
          "transitions": [
            [
              "EMPTY",
              "ALMOST_EMPTY",
              "wr_en && !rd_en && count <= ALMOST_EMPTY_THRESHOLD"
            ],
            [
              "EMPTY",
              "NORMAL",
              "wr_en && !rd_en && count > ALMOST_EMPTY_THRESHOLD && count < ALMOST_FULL_THRESHOLD"
            ],
            [
              "EMPTY",
              "ERROR",
              "rd_en && !wr_en"
            ],
            [
              "ALMOST_EMPTY",
              "EMPTY",
              "rd_en && !wr_en && count == 1"
            ],
            [
              "ALMOST_EMPTY",
              "NORMAL",
              "wr_en && count > ALMOST_EMPTY_THRESHOLD"
            ],
            [
              "NORMAL",
              "ALMOST_EMPTY",
              "rd_en && !wr_en && count <= ALMOST_EMPTY_THRESHOLD"
            ],
            [
              "NORMAL",
              "ALMOST_FULL",
              "wr_en && !rd_en && count >= ALMOST_FULL_THRESHOLD"
            ],
            [
              "ALMOST_FULL",
              "NORMAL",
              "rd_en && !wr_en && count < ALMOST_FULL_THRESHOLD"
            ],
            [
              "ALMOST_FULL",
              "FULL",
              "wr_en && !rd_en && count == DEPTH-1"
            ],
            [
              "FULL",
              "ALMOST_FULL",
              "rd_en && !wr_en"
            ],
            [
              "FULL",
              "ERROR",
              "wr_en && !rd_en"
            ],
            [
              "ERROR",
              "ERROR",
              "always (sticky error)"
            ]
          ],
          "description": "Controls FIFO state based on count and operation type"
        }
      ],
      "key_signals": [
        {
          "name": "mem",
          "width": "DATA_WIDTH * DEPTH",
          "description": "Internal memory array"
        },
        {
          "name": "wr_ptr",
          "width": "ADDR_WIDTH",
          "description": "Write pointer (circular)"
        },
        {
          "name": "rd_ptr",
          "width": "ADDR_WIDTH",
          "description": "Read pointer (circular)"
        },
        {
          "name": "count_reg",
          "width": "ADDR_WIDTH+1",
          "description": "Internal count register"
        },
        {
          "name": "wr_en_int",
          "width": 1,
          "description": "Internal write enable after collision resolution"
        },
        {
          "name": "rd_en_int",
          "width": 1,
          "description": "Internal read enable after collision resolution"
        },
        {
          "name": "overflow_cond",
          "width": 1,
          "description": "Overflow condition detection"
        },
        {
          "name": "underflow_cond",
          "width": 1,
          "description": "Underflow condition detection"
        },
        {
          "name": "ALMOST_FULL_THRESHOLD",
          "width": "ADDR_WIDTH+1",
          "description": "Threshold for almost_full flag (3/4 * DEPTH)"
        },
        {
          "name": "ALMOST_EMPTY_THRESHOLD",
          "width": "ADDR_WIDTH+1",
          "description": "Threshold for almost_empty flag (1/4 * DEPTH)"
        }
      ]
    }
  ],
  "interfaces": [
    {
      "name": "write_interface",
      "type": "custom",
      "signals": [
        "wr_en",
        "wr_data"
      ]
    },
    {
      "name": "read_interface",
      "type": "custom",
      "signals": [
        "rd_en",
        "rd_data"
      ]
    },
    {
      "name": "status_interface",
      "type": "custom",
      "signals": [
        "full",
        "empty",
        "almost_full",
        "almost_empty",
        "count",
        "error"
      ]
    },
    {
      "name": "clock_reset_interface",
      "type": "custom",
      "signals": [
        "clk",
        "rst_n"
      ]
    }
  ],
  "requirements": [
    {
      "id": "REQ-001",
      "description": "FIFO shall store data when wr_en is asserted and FIFO is not full",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-002",
      "description": "FIFO shall output data when rd_en is asserted and FIFO is not empty",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-003",
      "description": "rd_data shall be combinational (same cycle as rd_en)",
      "priority": "high",
      "category": "timing"
    },
    {
      "id": "REQ-004",
      "description": "full flag shall be asserted when count equals DEPTH",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-005",
      "description": "empty flag shall be asserted when count equals 0",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-006",
      "description": "almost_full flag shall be asserted when count >= 3/4 of DEPTH",
      "priority": "medium",
      "category": "functional"
    },
    {
      "id": "REQ-007",
      "description": "almost_empty flag shall be asserted when count <= 1/4 of DEPTH",
      "priority": "medium",
      "category": "functional"
    },
    {
      "id": "REQ-008",
      "description": "Simultaneous read/write operations shall be supported when FIFO is full",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-009",
      "description": "Simultaneous read/write operations shall be supported when FIFO is empty",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-010",
      "description": "error flag shall be asserted on overflow (write to full FIFO without read)",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-011",
      "description": "error flag shall be asserted on underflow (read from empty FIFO without write)",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-012",
      "description": "error flag shall be sticky (remain asserted once set)",
      "priority": "medium",
      "category": "functional"
    },
    {
      "id": "REQ-013",
      "description": "count shall accurately reflect number of valid entries",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-014",
      "description": "Write and read pointers shall wrap around correctly at DEPTH boundary",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-015",
      "description": "Reset shall clear all pointers, count, and error flag",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-016",
      "description": "Reset shall set empty flag and clear all other status flags",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-017",
      "description": "Data integrity shall be maintained (FIFO order preserved)",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-018",
      "description": "No data loss during normal operations",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-019",
      "description": "Status flags shall never have conflicting states (full && empty)",
      "priority": "high",
      "category": "functional"
    },
    {
      "id": "REQ-020",
      "description": "Count shall never exceed DEPTH",
      "priority": "high",
      "category": "functional"
    }
  ],
  "corner_cases": [
    {
      "id": "CC-001",
      "description": "Reset during active write operation",
      "how_to_test": "Assert reset while wr_en is high and verify clean state"
    },
    {
      "id": "CC-002",
      "description": "Reset during active read operation",
      "how_to_test": "Assert reset while rd_en is high and verify clean state"
    },
    {
      "id": "CC-003",
      "description": "Simultaneous read/write when FIFO is full",
      "how_to_test": "Fill FIFO, then assert both wr_en and rd_en simultaneously"
    },
    {
      "id": "CC-004",
      "description": "Simultaneous read/write when FIFO is empty",
      "how_to_test": "Empty FIFO, then assert both wr_en and rd_en simultaneously"
    },
    {
      "id": "CC-005",
      "description": "Multiple consecutive writes to fill FIFO",
      "how_to_test": "Write DEPTH+1 entries and verify overflow detection"
    },
    {
      "id": "CC-006",
      "description": "Multiple consecutive reads to empty FIFO",
      "how_to_test": "Read from empty FIFO and verify underflow detection"
    },
    {
      "id": "CC-007",
      "description": "Pointer wraparound at maximum address",
      "how_to_test": "Fill and empty FIFO multiple times to test pointer wraparound"
    },
    {
      "id": "CC-008",
      "description": "Almost_full threshold boundary conditions",
      "how_to_test": "Write exactly to almost_full threshold and verify flag behavior"
    },
    {
      "id": "CC-009",
      "description": "Almost_empty threshold boundary conditions",
      "how_to_test": "Read to exactly almost_empty threshold and verify flag behavior"
    },
    {
      "id": "CC-010",
      "description": "Back-to-back write/read operations",
      "how_to_test": "Alternate write and read operations rapidly"
    },
    {
      "id": "CC-011",
      "description": "Write enable without data change",
      "how_to_test": "Keep wr_data constant while toggling wr_en"
    },
    {
      "id": "CC-012",
      "description": "Read enable when FIFO transitions from empty to non-empty",
      "how_to_test": "Assert rd_en while writing first entry to empty FIFO"
    },
    {
      "id": "CC-013",
      "description": "Write enable when FIFO transitions from full to non-full",
      "how_to_test": "Assert wr_en while reading last entry from full FIFO"
    },
    {
      "id": "CC-014",
      "description": "Error flag persistence",
      "how_to_test": "Trigger error condition and verify flag remains set"
    },
    {
      "id": "CC-015",
      "description": "Maximum data width values",
      "how_to_test": "Write and read all 1s and all 0s patterns"
    },
    {
      "id": "CC-016",
      "description": "Minimum FIFO depth (DEPTH=1)",
      "how_to_test": "Instantiate with DEPTH=1 and test all operations"
    },
    {
      "id": "CC-017",
      "description": "Large FIFO depth (power of 2 and non-power of 2)",
      "how_to_test": "Test with various DEPTH values including edge cases"
    },
    {
      "id": "CC-018",
      "description": "Clock edge timing with setup/hold violations",
      "how_to_test": "Use timing-aware testbench with clock edge variations"
    },
    {
      "id": "CC-019",
      "description": "Rapid fill and empty cycles",
      "how_to_test": "Continuously fill and empty FIFO in loops"
    },
    {
      "id": "CC-020",
      "description": "Random access patterns",
      "how_to_test": "Generate random sequences of read/write operations"
    }
  ]
}