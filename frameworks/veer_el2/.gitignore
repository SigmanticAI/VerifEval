# Per-run artifacts (re-generated by veer_bench.py); the dir layout itself is committed.
runs/
spec/
reports/
artifacts/
results/
**/__pycache__/
*.pyc
# Keep .gitkeep files so empty folder structure is still tracked
!runs/.gitkeep
!spec/.gitkeep
!reports/.gitkeep
!artifacts/.gitkeep
!results/.gitkeep
