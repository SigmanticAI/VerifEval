#!/usr/bin/env python3
"""
VUnit Run Script - VHDL Testbench
=================================

Auto-generated by TB Eval Framework
Generated: {{ generation_time }}
Template: vhdl_run.py.j2

Project: {{ project_name }}
TB Type: VHDL
Simulator: {{ simulator }}
"""

from pathlib import Path
from vunit import VUnit

# =============================================================================
# Configuration
# =============================================================================

ROOT = Path(__file__).parent
SUBMISSION_DIR = ROOT / "{{ rel_path }}"

# VHDL files only
VHDL_FILES = {{ vhdl_files | to_python_list }}

# =============================================================================
# VUnit Setup
# =============================================================================

def create_vunit():
    """Create and configure VUnit instance for VHDL"""
    vu = VUnit.from_argv()
    
    {% if simulator == 'ghdl' %}
    # GHDL options
    vu.set_compile_option("ghdl.a_flags", ["--std=08", "-frelaxed"])
    vu.set_sim_option("ghdl.elab_flags", ["-frelaxed"])
    {% elif simulator in ['questa', 'modelsim'] %}
    # Questa/ModelSim VHDL options
    vu.set_compile_option("modelsim.vcom_flags", [
        "-2008",
        "+acc=r",
        {% if coverage_enabled %}
        "+cover=bcesft",
        {% endif %}
    ])
    
    vu.set_sim_option("modelsim.vsim_flags", [
        "-voptargs=+acc",
        {% if coverage_enabled %}
        "-coverage",
        {% endif %}
    ])
    {% endif %}
    
    return vu


def add_sources(vu):
    """Add VHDL sources"""
    lib = vu.add_library("work")
    
    for vhdl_file in VHDL_FILES:
        file_path = ROOT / vhdl_file
        if file_path.exists():
            lib.add_source_file(str(file_path))
        else:
            print(f"Warning: File not found: {file_path}")
    
    return lib


def configure_tests(lib):
    """Configure VHDL test benches"""
    {% if top_module %}
    try:
        tb = lib.test_bench("{{ top_module }}")
    except KeyError:
        print("Warning: Testbench '{{ top_module }}' not found")
    {% endif %}


# =============================================================================
# Main
# =============================================================================

def main():
    vu = create_vunit()
    lib = add_sources(vu)
    configure_tests(lib)
    vu.main()


if __name__ == "__main__":
    main()
