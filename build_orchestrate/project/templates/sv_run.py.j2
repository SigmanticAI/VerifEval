#!/usr/bin/env python3
"""
VUnit Run Script - SystemVerilog Testbench
==========================================

Auto-generated by TB Eval Framework
Generated: {{ generation_time }}
Template: sv_run.py.j2

Project: {{ project_name }}
TB Type: Plain SystemVerilog
Simulator: {{ simulator }}
"""

from pathlib import Path
from vunit import VUnit

# =============================================================================
# Configuration
# =============================================================================

ROOT = Path(__file__).parent
SUBMISSION_DIR = ROOT / "{{ rel_path }}"

DUT_FILES = {{ dut_files | to_python_list }}

TB_FILES = {{ tb_files | to_python_list }}

# =============================================================================
# VUnit Setup
# =============================================================================

def create_vunit():
    """Create and configure VUnit instance"""
    vu = VUnit.from_argv()
    
    # SystemVerilog compile options
    {% if simulator in ['questa', 'modelsim'] %}
    vu.set_compile_option("modelsim.vlog_flags", [
        "-sv",
        "+acc=r",
        "-timescale", "1ns/1ps",
        {% if coverage_enabled %}
        "+cover=bcesft",
        {% endif %}
    ])
    
    vu.set_sim_option("modelsim.vsim_flags", [
        "-voptargs=+acc",
        {% if coverage_enabled %}
        "-coverage",
        {% endif %}
    ])
    {% elif simulator == 'ghdl' %}
    # GHDL doesn't support SystemVerilog directly
    print("Warning: GHDL selected but files are SystemVerilog")
    {% endif %}
    
    return vu


def add_sources(vu):
    """Add SystemVerilog sources"""
    lib = vu.add_library("work")
    
    # Add DUT files
    for dut_file in DUT_FILES:
        file_path = ROOT / dut_file
        if file_path.exists():
            lib.add_source_file(str(file_path))
    
    # Add TB files
    for tb_file in TB_FILES:
        file_path = ROOT / tb_file
        if file_path.exists():
            lib.add_source_file(str(file_path))
    
    return lib


def configure_tests(lib):
    """Configure test benches"""
    {% if top_module %}
    # Set up main testbench
    try:
        tb = lib.test_bench("{{ top_module }}")
        # Add any test configurations here
    except KeyError:
        print("Warning: Testbench '{{ top_module }}' not found")
    {% endif %}


# =============================================================================
# Main
# =============================================================================

def main():
    vu = create_vunit()
    lib = add_sources(vu)
    configure_tests(lib)
    vu.main()


if __name__ == "__main__":
    main()
