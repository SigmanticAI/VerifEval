#!/usr/bin/env python3
"""
VUnit Run Script - CocoTB Integration
=====================================

Auto-generated by TB Eval Framework
Generated: {{ generation_time }}
Template: cocotb_run.py.j2

Project: {{ project_name }}
TB Type: CocoTB / PyUVM
Simulator: {{ simulator }}

Note: CocoTB tests are run via Makefile, but this script
provides VUnit-style compilation and organization.
"""

from pathlib import Path
import subprocess
import sys
import os

# =============================================================================
# Configuration
# =============================================================================

ROOT = Path(__file__).parent
SUBMISSION_DIR = ROOT / "{{ rel_path }}"
MAKEFILE_PATH = ROOT / "Makefile"

# Simulation settings
SIM = os.environ.get("SIM", "{{ 'verilator' if simulator == 'verilator' else 'questa' }}")
TOPLEVEL = os.environ.get("TOPLEVEL", "{{ top_module or 'top' }}")
MODULE = os.environ.get("MODULE", "{{ cocotb_module }}")

# File lists
DUT_FILES = {{ dut_files | to_python_list }}

TB_FILES = {{ tb_files | to_python_list }}

# =============================================================================
# CocoTB Execution
# =============================================================================

def run_cocotb_tests():
    """Run CocoTB tests via Makefile"""
    env = os.environ.copy()
    
    # Set CocoTB environment variables
    env["SIM"] = SIM
    env["TOPLEVEL"] = TOPLEVEL
    env["TOPLEVEL_LANG"] = "verilog"
    env["MODULE"] = MODULE
    
    # Add Python path for test modules
    python_path = env.get("PYTHONPATH", "")
    tb_dir = str(SUBMISSION_DIR / "tb")
    env["PYTHONPATH"] = f"{tb_dir}:{python_path}" if python_path else tb_dir
    
    {% if coverage_enabled %}
    # Enable coverage
    env["COCOTB_COVERAGE"] = "1"
    {% endif %}
    
    # Run make
    print(f"Running CocoTB tests...")
    print(f"  SIM={SIM}")
    print(f"  TOPLEVEL={TOPLEVEL}")
    print(f"  MODULE={MODULE}")
    
    result = subprocess.run(
        ["make", "-f", str(MAKEFILE_PATH)],
        cwd=str(ROOT),
        env=env,
    )
    
    return result.returncode


def run_with_questa():
    """Run CocoTB with Questa simulator"""
    # For Questa, we can use the FLI or VPI interface
    env = os.environ.copy()
    
    env["SIM"] = "questa"
    env["TOPLEVEL"] = TOPLEVEL
    env["TOPLEVEL_LANG"] = "verilog"
    env["MODULE"] = MODULE
    
    # Questa-specific settings
    env["COCOTB_HDL_TIMEPRECISION"] = "1ns"
    
    {% if coverage_enabled %}
    env["QUESTA_COVERAGE"] = "1"
    {% endif %}
    
    result = subprocess.run(
        ["make", "-f", str(MAKEFILE_PATH)],
        cwd=str(ROOT),
        env=env,
    )
    
    return result.returncode


# =============================================================================
# VUnit-Style Compilation (for consistency)
# =============================================================================

def compile_with_vunit():
    """
    Compile sources using VUnit (optional)
    This provides consistent compilation before CocoTB execution
    """
    try:
        from vunit import VUnit
        
        vu = VUnit.from_argv(compile_builtins=False)
        lib = vu.add_library("work")
        
        for dut_file in DUT_FILES:
            file_path = ROOT / dut_file
            if file_path.exists():
                lib.add_source_file(str(file_path))
        
        # Compile only, don't run
        vu.set_sim_option("modelsim.vsim_flags", ["-c", "-do", "quit"])
        
        print("Pre-compiling with VUnit...")
        # Note: This is optional - CocoTB will also compile
        
    except ImportError:
        print("VUnit not available, skipping pre-compilation")


# =============================================================================
# Main
# =============================================================================

def main():
    """Main entry point"""
    args = sys.argv[1:]
    
    # Check for compile-only flag
    if "--compile" in args:
        compile_with_vunit()
        return 0
    
    # Check for Questa-specific run
    if SIM == "questa" or "--questa" in args:
        return run_with_questa()
    
    # Default: run CocoTB tests
    return run_cocotb_tests()


if __name__ == "__main__":
    sys.exit(main())
