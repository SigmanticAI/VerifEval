    vu.set_sim_option("modelsim.vsim_flags", {{ sim_options.get('vsim_flags', []) }} + ["-coverage"])
    {% else %}
    vu.set_sim_option("modelsim.vsim_flags", {{ sim_options.get('vsim_flags', []) }})
    {% endif %}
    
    return vu


def add_sources(vu):
    """Add source files to VUnit"""
    # Create work library
    lib = vu.add_library("work")
    
    # Add DUT files
    for dut_file in DUT_FILES:
        file_path = ROOT / dut_file
        if file_path.exists():
            lib.add_source_file(str(file_path))
        else:
            print(f"Warning: DUT file not found: {file_path}")
    
    # Add testbench files
    for tb_file in TB_FILES:
        file_path = ROOT / tb_file
        if file_path.exists():
            lib.add_source_file(str(file_path))
        else:
            print(f"Warning: TB file not found: {file_path}")
    
    return lib


